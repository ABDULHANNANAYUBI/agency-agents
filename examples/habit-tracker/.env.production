# ═══════════════════════════════════════════════════════════════════════════
#  HabitForge (Next.js) — Production Environment Variables
#
#  ⚠  Values prefixed with NEXT_PUBLIC_ are embedded in the client bundle
#     at build time — never put secrets in NEXT_PUBLIC_ variables.
#
#  HOW TO USE
#  ──────────
#  Vercel:          paste each variable in Project → Settings → Environment Variables
#  Docker / VPS:    pass via docker run -e or env_file in docker-compose.yml
#  GitHub Actions:  store as repository secrets, inject in the build step
# ═══════════════════════════════════════════════════════════════════════════

# ── Build / Runtime ───────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Docker image version tag (set automatically by CI, override manually if needed)
APP_VERSION=latest

# ── URLs ─────────────────────────────────────────────────────────────────────
# Public URL of this Next.js app (used for OG meta, canonical links, etc.)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# URL of the HabitTracker .NET API
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ── Security ─────────────────────────────────────────────────────────────────
# Content Security Policy header — tighten further once your CDN/asset hosts are known
# (injected via next.config.mjs headers() if you add that feature)
# CSP_REPORT_URI=https://your-csp-report-endpoint.com

# ── Analytics (optional — uncomment when ready) ───────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=G-XXXXXXXXXX
