# ═══════════════════════════════════════════════════════════════════════════
#  HabitTracker API — Production Environment Variables
#
#  ⚠  NEVER commit this file with real values to source control.
#     Add .env.production to your .gitignore.
#
#  HOW TO USE
#  ──────────
#  Docker Compose:   env_file: .env.production
#  GitHub Actions:   store each var as a repository secret, then inject via
#                    the deploy step (see .github/workflows/deploy.yml).
#  systemd service:  EnvironmentFile=/etc/habittracker/env.production
# ═══════════════════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5000
DOTNET_RUNNING_IN_CONTAINER=true

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — single server / low traffic)
ConnectionStrings__DefaultConnection=Data Source=/data/habittracker.db

# PostgreSQL (recommended for multi-instance deployments — uncomment & fill in)
# ConnectionStrings__DefaultConnection=Host=db-host;Port=5432;Database=habittracker;Username=habitapp;Password=CHANGE_ME;SSL Mode=Require;Trust Server Certificate=true

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong key: openssl rand -base64 64
Jwt__Key=REPLACE_WITH_64_CHAR_RANDOM_SECRET_openssl_rand_base64_64
Jwt__Issuer=HabitTracker.API
Jwt__Audience=HabitTracker.Client
Jwt__ExpiryDays=7

# ── CORS ─────────────────────────────────────────────────────────────────────
AllowedOrigins__0=https://your-domain.com
AllowedOrigins__1=https://www.your-domain.com

# ── Logging ───────────────────────────────────────────────────────────────────
Logging__LogLevel__Default=Warning
Logging__LogLevel__HabitTracker.API=Information
