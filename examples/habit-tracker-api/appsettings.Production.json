{
  // ─────────────────────────────────────────────────────────────────────────
  // appsettings.Production.json
  //
  // NON-SECRET values only. Secrets (Jwt:Key, connection string password)
  // must be supplied via environment variables at runtime:
  //
  //   ConnectionStrings__DefaultConnection=Host=...
  //   Jwt__Key=<64-char random string>
  //
  // ASP.NET Core automatically overrides any key here with a matching
  // environment variable (using __ as the section separator).
  // ─────────────────────────────────────────────────────────────────────────

  "ConnectionStrings": {
    // SQLite (single-server / low-traffic).
    // For higher traffic switch to PostgreSQL and set via env var:
    //   ConnectionStrings__DefaultConnection=Host=db;Database=habittracker;Username=app;Password=<secret>
    "DefaultConnection": "Data Source=/data/habittracker.db"
  },

  "Jwt": {
    // Key MUST be overridden via Jwt__Key environment variable — never store
    // the real secret in this file or commit it to source control.
    "Key": "REPLACE_VIA_ENV_VAR_JWT__KEY",
    "Issuer": "HabitTracker.API",
    "Audience": "HabitTracker.Client",
    "ExpiryDays": 7
  },

  // Comma-separated list of allowed CORS origins.
  // Override via AllowedOrigins__0 / AllowedOrigins__1 env vars if needed.
  "AllowedOrigins": [
    "https://your-domain.com",
    "https://www.your-domain.com"
  ],

  "AllowedHosts": "your-api-domain.com;www.your-api-domain.com",

  // Production: suppress noisy framework logs; keep app-level at Warning+.
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "HabitTracker.API": "Information"
    }
  },

  // Kestrel HTTPS — certificate path can be overridden with env vars
  // or handled externally by Nginx / a reverse proxy (recommended).
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  }
}
