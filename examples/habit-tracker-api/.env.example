# ═══════════════════════════════════════════════════════════════════════════
#  HabitTracker API — Environment Variables Reference
#
#  Copy this file to .env.production and fill in real values.
#  This file is safe to commit — it contains no secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5000
DOTNET_RUNNING_IN_CONTAINER=true

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite
ConnectionStrings__DefaultConnection=Data Source=/data/habittracker.db

# PostgreSQL (uncomment for multi-instance deployments)
# ConnectionStrings__DefaultConnection=Host=<host>;Port=5432;Database=habittracker;Username=<user>;Password=<password>;SSL Mode=Require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
Jwt__Key=<64-char-random-secret>
Jwt__Issuer=HabitTracker.API
Jwt__Audience=HabitTracker.Client
Jwt__ExpiryDays=7

# ── CORS ─────────────────────────────────────────────────────────────────────
AllowedOrigins__0=https://your-domain.com
AllowedOrigins__1=https://www.your-domain.com

# ── Logging ───────────────────────────────────────────────────────────────────
Logging__LogLevel__Default=Warning
Logging__LogLevel__HabitTracker.API=Information
